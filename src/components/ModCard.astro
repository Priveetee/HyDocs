---
import type { Mod } from "../data/types";

interface Props {
	mod: Mod;
}

const { mod } = Astro.props;
const initials = mod.name
	.split(" ")
	.map((w: string) => w[0])
	.join("")
	.slice(0, 2)
	.toUpperCase();
---

<a class="mod-card" id={`mod-${mod.id}`} data-category={mod.category} href={`/mods/${mod.id}`}>
	<div class="mod-avatar" aria-hidden="true">
		{mod.imageUrl
			? <img src={mod.imageUrl} alt="" width="36" height="36" loading="lazy" />
			: <span>{initials}</span>
		}
	</div>
	<div class="mod-summary">
		<span class="mod-name">{mod.name}</span>
		<span class="mod-meta">
			<span class="mod-cat">{mod.category}</span>
			<span class="mod-ver">{mod.version}</span>
		</span>
	</div>
	<span class="mod-author">{mod.author}</span>
	{mod.curseforgeUrl && (
		<span class="ext-badge">CF</span>
	)}
	<svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
		<path d="M5 3L9 7L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
	</svg>
</a>

<style>
	.mod-card {
		display: flex; align-items: center; gap: 1rem;
		width: 100%; padding: 1rem 0.5rem;
		text-decoration: none;
		border-bottom: 1px solid var(--border-muted);
		transition: background 0.15s; border-radius: 6px;
	}
	.mod-card:first-child { border-top: 1px solid var(--border-muted); }
	.mod-card:hover { background: var(--surface-hover); }
	.mod-card:hover .mod-name { color: var(--accent); }
	.mod-avatar {
		width: 40px; height: 40px; border-radius: 10px;
		background: var(--surface); border: 1px solid var(--border);
		display: flex; align-items: center; justify-content: center;
		flex-shrink: 0; overflow: hidden;
		font-size: 0.75rem; font-weight: 700; color: var(--accent);
		font-family: "Geist Mono", monospace; letter-spacing: 0.02em;
	}
	.mod-avatar img { width: 100%; height: 100%; object-fit: cover; }
	.mod-summary { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.25rem; }
	.mod-name {
		font-size: 1rem; font-weight: 600; color: var(--text);
		white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
		letter-spacing: -0.01em; transition: color 0.15s;
	}
	.mod-meta { display: flex; align-items: center; gap: 0.5rem; font-size: 0.775rem; }
	.mod-cat { color: var(--text-3); }
	.mod-ver {
		color: var(--text-3); font-family: "Geist Mono", monospace;
		background: var(--surface); border: 1px solid var(--border-muted);
		padding: 0.05rem 0.4rem; border-radius: 3px;
	}
	.mod-author { font-size: 0.825rem; color: var(--text-3); white-space: nowrap; flex-shrink: 0; }
	.ext-badge {
		font-size: 0.7rem; font-weight: 600; color: var(--text-3);
		border: 1px solid var(--border); padding: 0.2rem 0.45rem;
		border-radius: 4px; flex-shrink: 0;
	}
	.arrow { color: var(--text-3); flex-shrink: 0; transition: color 0.15s; }
	.mod-card:hover .arrow { color: var(--accent); }
	@media (max-width: 768px) {
		.mod-author { display: none; }
		.mod-name { font-size: 0.95rem; }
	}
</style>
