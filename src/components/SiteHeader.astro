---
interface Props {
	modCount: number;
}
const { modCount } = Astro.props;
---

<header class="site-header">
	<div class="header-inner">
		<div class="header-brand">
			<img src="/logo.svg" alt="" class="site-logo" aria-hidden="true" />
			<h1 class="site-title">HyDocs</h1>
			<span class="site-sub">{modCount} mods installés</span>
		</div>
		<div class="header-actions">
			<button class="filter-toggle" id="filter-toggle" aria-label="Filtrer par catégorie">
				<svg width="15" height="15" viewBox="0 0 16 16" fill="none">
					<path d="M2 4h12M4 8h8M6 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
				</svg>
				<span>Catégories</span>
			</button>
			<button class="search-trigger" id="search-trigger" aria-label="Rechercher">
				<svg width="15" height="15" viewBox="0 0 16 16" fill="none">
					<circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
					<path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
				</svg>
				<span class="search-label">Rechercher un mod...</span>
				<kbd id="search-kbd">⌘K</kbd>
			</button>
		</div>
	</div>
</header>

<style>
	.site-header {
		border-bottom: 1px solid var(--border);
		padding: 0 2rem;
		height: 64px;
		display: flex;
		align-items: center;
		position: sticky;
		top: 0;
		background: rgba(20, 20, 20, 0.92);
		backdrop-filter: blur(12px);
		z-index: 100;
	}

	.header-inner {
		width: 100%;
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.header-brand {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		min-width: 0;
	}

	.site-logo { width: 30px; height: 30px; flex-shrink: 0; }

	.site-title {
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--text);
		white-space: nowrap;
	}

	.site-sub {
		font-size: 0.8rem;
		color: var(--text-3);
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 0.2rem 0.65rem;
		white-space: nowrap;
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	.filter-toggle {
		display: none;
		align-items: center;
		gap: 0.4rem;
		padding: 0.5rem 0.85rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 8px;
		color: var(--text-3);
		font-size: 0.875rem;
		font-family: inherit;
		cursor: pointer;
		transition: border-color 0.15s, color 0.15s;
		white-space: nowrap;
	}

	.filter-toggle:hover { border-color: var(--accent); color: var(--text-2); }
	.filter-toggle.active { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

	.search-trigger {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.5rem 1rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 8px;
		color: var(--text-3);
		font-size: 0.875rem;
		cursor: pointer;
		transition: border-color 0.15s, color 0.15s, background 0.15s;
		white-space: nowrap;
		min-width: 220px;
		font-family: inherit;
	}

	.search-trigger .search-label { flex: 1; text-align: left; }
	.search-trigger:hover { border-color: var(--accent); color: var(--text-2); background: var(--surface-hover); }

	.search-trigger kbd {
		font-size: 0.7rem;
		padding: 0.1rem 0.4rem;
		border: 1px solid var(--border);
		border-radius: 4px;
		background: var(--bg);
		font-family: "Geist Mono", monospace;
		color: var(--text-3);
	}

	@media (max-width: 768px) {
		.site-header { padding: 0 1rem; }
		.site-sub { display: none; }
		.filter-toggle { display: flex; }
		.search-trigger { min-width: unset; padding: 0.5rem; }
		.search-trigger .search-label { display: none; }
		.search-trigger kbd { display: none; }
	}
</style>
