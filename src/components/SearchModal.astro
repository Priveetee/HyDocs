---
---

<div id="search-modal" class="overlay" aria-modal="true" role="dialog" hidden>
	<div class="modal">
		<div class="input-row">
			<svg width="15" height="15" viewBox="0 0 16 16" fill="none" class="search-icon">
				<circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
				<path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
			</svg>
			<input id="search-input" type="text" placeholder="Rechercher un mod..." autocomplete="off" spellcheck="false" />
			<kbd class="esc-hint">Esc</kbd>
		</div>
		<ul id="search-results" class="results" role="listbox"></ul>
		<p id="search-empty" class="empty" hidden>Aucun résultat.</p>
		<div class="footer-hint">
			<span><kbd>↑↓</kbd> naviguer</span>
			<span><kbd>↵</kbd> aller au mod</span>
			<span><kbd>Esc</kbd> fermer</span>
		</div>
	</div>
</div>

<style>
	.overlay {
		position: fixed; inset: 0;
		background: var(--modal-overlay);
		z-index: 1000;
		display: flex; align-items: flex-start; justify-content: center;
		padding-top: 10vh;
	}
	.overlay[hidden] { display: none; }
	.modal {
		width: 100%; max-width: 580px;
		background: var(--modal-bg);
		border: 1px solid var(--border); border-radius: 14px;
		overflow: hidden;
		box-shadow: 0 32px 80px rgba(0,0,0,0.75), 0 0 0 1px rgba(232,168,62,0.05);
	}
	@media (max-width: 768px) {
		.overlay { padding-top: 0; align-items: flex-end; }
		.modal { border-radius: 16px 16px 0 0; border-bottom: none; max-width: 100%; }
		.footer-hint { display: none; }
		.results { max-height: 55vh; }
	}
	.input-row {
		display: flex; align-items: center; gap: 0.75rem;
		padding: 0.9rem 1.1rem;
		border-bottom: 1px solid var(--border-muted);
	}
	.search-icon { color: var(--text-3); flex-shrink: 0; }
	input {
		flex: 1; background: none; border: none; outline: none;
		color: var(--text); font-family: inherit; font-size: 0.975rem;
	}
	input::placeholder { color: var(--text-3); }
	.esc-hint {
		font-size: 0.7rem; padding: 0.15rem 0.4rem;
		border: 1px solid var(--border); border-radius: 4px;
		color: var(--text-3); background: var(--bg);
	}
	.results { list-style: none; max-height: 380px; overflow-y: auto; }
	.results li {
		display: flex; align-items: center; gap: 0.85rem;
		padding: 0.75rem 1.1rem; cursor: pointer;
		border-bottom: 1px solid var(--border-muted);
		transition: background 0.1s;
	}
	.results li:last-child { border-bottom: none; }
	.results li:hover, .results li[aria-selected="true"] { background: var(--accent-dim); }
	.results li[aria-selected="true"] .result-name { color: var(--accent); }
	.result-img, .result-img-placeholder {
		width: 32px; height: 32px; border-radius: 6px;
		background: var(--surface); flex-shrink: 0;
	}
	.result-img { object-fit: cover; }
	.result-img-placeholder {
		display: flex; align-items: center; justify-content: center;
		font-size: 0.7rem; color: var(--text-3);
		font-family: "Geist Mono", monospace;
	}
	.result-body { flex: 1; min-width: 0; }
	.result-name { font-size: 0.925rem; font-weight: 500; color: var(--text); }
	.result-cat {
		display: inline-block; margin-top: 0.25rem;
		font-size: 0.7rem; font-weight: 600; letter-spacing: 0.02em;
		color: var(--accent); background: var(--accent-dim);
		border-radius: 4px; padding: 0.1rem 0.45rem;
	}
	.footer-hint {
		display: flex; gap: 1.25rem;
		padding: 0.6rem 1.1rem;
		border-top: 1px solid var(--border-muted);
		font-size: 0.72rem; color: var(--text-3);
	}
	.footer-hint kbd {
		font-family: "Geist Mono", monospace;
		background: var(--surface); border: 1px solid var(--border);
		border-radius: 3px; padding: 0.05rem 0.3rem; font-size: 0.7rem;
	}
	.empty { padding: 1.5rem 1.1rem; color: var(--text-3); font-size: 0.9rem; }
</style>

<script src="../scripts/search-modal.ts"></script>
