---
import CommandList from "../../components/CommandList.astro";
import ConfigTable from "../../components/ConfigTable.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ALL_MODS } from "../../data/mods";

export function getStaticPaths() {
	return ALL_MODS.map((mod) => ({ params: { id: mod.id }, props: { mod } }));
}

const { mod } = Astro.props;
const initials = mod.name
	.split(" ")
	.map((w: string) => w[0])
	.join("")
	.slice(0, 2)
	.toUpperCase();
---

<BaseLayout
	title={`${mod.name} — HyDocs`}
	description={mod.description}
>
	<SiteHeader modCount={ALL_MODS.length} />

	<div class="page">
		<div class="container">
			<a href="/" class="back-link">
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none">
					<path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
				Tous les mods
			</a>

			<header class="mod-header">
				<div class="mod-avatar" aria-hidden="true">
					{mod.imageUrl
						? <img src={mod.imageUrl} alt="" width="56" height="56" loading="eager" />
						: <span>{initials}</span>
					}
				</div>
				<div class="mod-titles">
					<h1 class="mod-name">{mod.name}</h1>
					<div class="mod-meta">
						<span class="meta-cat">{mod.category}</span>
						<span class="meta-sep">·</span>
						<span class="meta-item">v{mod.version}</span>
						<span class="meta-sep">·</span>
						<span class="meta-item">par {mod.author}</span>
						{mod.curseforgeUrl && (
							<span class="meta-sep">·</span>
							<a href={mod.curseforgeUrl} target="_blank" rel="noopener noreferrer" class="ext-link">
								CurseForge ↗
							</a>
						)}
					</div>
				</div>
			</header>

			<div class="sections">
				<section class="section">
					<p class="label">Description</p>
					<p class="body-text">{mod.description}</p>
				</section>

				<section class="section">
					<p class="label">Utilisation</p>
					<p class="body-text">{mod.usage}</p>
				</section>

				<CommandList commands={mod.commands} />
				<ConfigTable params={mod.configParams} />
			</div>
		</div>
	</div>
</BaseLayout>

<style>
	.page {
		max-width: 1400px; margin: 0 auto;
		padding: 2rem 2rem 4rem;
		width: 100%;
	}
	.container { max-width: 760px; margin: 0 auto; }
	.back-link {
		display: inline-flex; align-items: center; gap: 0.4rem;
		font-size: 0.85rem; color: var(--text-3); text-decoration: none;
		margin-bottom: 2rem;
		transition: color 0.15s;
	}
	.back-link:hover { color: var(--accent); }
	.mod-header {
		display: flex; align-items: center; gap: 1.25rem;
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border-muted);
	}
	.mod-avatar {
		width: 56px; height: 56px; border-radius: 14px; flex-shrink: 0;
		background: var(--surface); border: 1px solid var(--border);
		display: flex; align-items: center; justify-content: center;
		overflow: hidden;
		font-size: 1rem; font-weight: 700; color: var(--accent);
		font-family: "Geist Mono", monospace;
	}
	.mod-avatar img { width: 100%; height: 100%; object-fit: cover; }
	.mod-titles { display: flex; flex-direction: column; gap: 0.5rem; }
	.mod-name { font-size: 1.6rem; font-weight: 700; letter-spacing: -0.02em; color: var(--text); }
	.mod-meta { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
	.meta-cat {
		font-size: 0.75rem; font-weight: 600; letter-spacing: 0.03em;
		color: var(--accent); background: var(--accent-dim);
		padding: 0.2rem 0.55rem; border-radius: 4px;
	}
	.meta-sep { color: var(--border); }
	.meta-item { font-size: 0.85rem; color: var(--text-3); }
	.ext-link {
		font-size: 0.85rem; color: var(--text-3); text-decoration: none;
		transition: color 0.1s;
	}
	.ext-link:hover { color: var(--accent); }
	.sections { display: flex; flex-direction: column; gap: 2rem; }
	.section { display: flex; flex-direction: column; gap: 0.5rem; }
	.label {
		font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
		letter-spacing: 0.08em; color: var(--text-3);
	}
	.body-text { font-size: 0.975rem; color: var(--text-2); line-height: 1.75; }
	@media (max-width: 768px) {
		.page { padding: 1.25rem 1rem 3rem; }
		.mod-name { font-size: 1.3rem; }
	}
</style>
